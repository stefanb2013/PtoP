PROGRAM _CYCLIC
(* cyclic program *)

bcd0000000000000000000000000000.x0000000000000000000000000000000 = bcd0000000000000000000000000000.x0000000000000000000000000000000
bcd0000000000000000000000000000.y1111111111111111111111111111111 = bcd0000000000000000000000000000.y1111111111111111111111111111111


