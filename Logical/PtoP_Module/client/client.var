	ClientConnectResponse : ClientConnectResponse_typ; (*Antwort PV Anmeldung: Client -> Server*)
	PVEvent : PVEvent_typ; (*Eventtelegramm: Server -> Client*)
	PVEventX : PVEventX_typ; (*Eventtelegramm: Server -> Client (geblockter Modus)*)
	PVEventXCopy : PVEventX_typ; (*Eventtelegramm: Server -> Client (einfachter Modus)*)
	PVEventAcknowledge : PVEventAcknowledge_typ; (*BestĂ¤tigung Eventtelegramme Client -> Server*)
	LifeCheckRequest : LifeCheckRequest_typ; (*Lifecheck - Anforderung Client -> Server*)
	LifeCheckResponse : LifeCheckResponse_typ; (*Lifecheck - Antwort Server - Client*)
	ClientLink : ClientLink_typ; (*Link des Clients auf Server*)
	NAK : AckResponse_typ; (*Bestaetigung Link: Server -> Client*)
END_VAR
